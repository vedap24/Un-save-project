# Un{save} Environment Variables
# Copy this file to .env and fill in your values

# Port for the server (default: 3000)
PORT=3000

# Path to the SQLite database file (relative to project root)
DB_PATH=./backend/data/unsave.db

# Vercel Postgres (Optional for local dev, required for production)
# Get these from the Vercel Dashboard -> Storage -> Postgres
POSTGRES_URL=postgres://default:password@ep-host.region.aws.neon.tech:5432/verceldb?sslmode=require
